# WebSocket backend URL used by useMatchSocket
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Optional explicit HTTP API base URL for matchmaking requests.
# If omitted, matchmaking derives HTTP base from NEXT_PUBLIC_WS_URL.
# NEXT_PUBLIC_API_URL=http://localhost:8080

# Deposit signing mode:
# - mock: bypasses real wallet transaction and sends mock signature
# - phantom: performs real wallet transaction signing flow
NEXT_PUBLIC_DEPOSIT_MODE=

# Settlement confirmation mode:
# - mock: local UI confirmation only
# - phantom: performs wallet signing flow for settlement release intent
NEXT_PUBLIC_SETTLEMENT_MODE=

# Dev-only fallback for /play identity when wallet is disconnected:
# - true: allows query/fallback address
# - false: requires wallet connection
NEXT_PUBLIC_ALLOW_DEV_ADDRESS_FALLBACK=

# Dev-only fallback for opponent character on found/deposit screen:
# - true: derives deterministic placeholder character from opponent wallet
# - false: shows neutral/syncing state until backend provides authoritative character
NEXT_PUBLIC_ALLOW_DEV_CHARACTER_FALLBACK=

# Dev-only lobby state preview toggles (?previewPhase=...):
# - true: enables local preview query params
# - false: disables preview phase rendering in normal/demo mode
NEXT_PUBLIC_ALLOW_DEV_ROOM_PREVIEW=
